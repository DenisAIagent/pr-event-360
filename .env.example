# ─── Base de données ────────────────────────────────────────────────
# Connexion PostgreSQL (locale = docker-compose ci-dessous)
DATABASE_URL=postgres://prevent:prevent@localhost:5432/pr_event_360

# ─── Serveur ────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# URL publique du back-end (sert à composer les liens tokenisés des journalistes)
PUBLIC_BASE_URL=http://localhost:4000
# URL du front (CORS)
CLIENT_URL=http://localhost:5173

# ─── Authentification back-office ───────────────────────────────────
# Secret de signature JWT — générer une valeur aléatoire forte en production
JWT_SECRET=change-me-in-production

# ─── Notifications (email / SMS) ────────────────────────────────────
# Démarrer en simulation : les messages sont journalisés et stockés, jamais envoyés.
# Passer à "live" UNIQUEMENT après validation visuelle du parcours complet.
NOTIFICATIONS_MODE=simulation        # simulation | live
EMAIL_PROVIDER=brevo                 # brevo
SMS_PROVIDER=twilio                  # twilio | brevo

# Brevo (email + SMS optionnel) — requis si NOTIFICATIONS_MODE=live
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=PR Event 360
BREVO_SMS_SENDER=PREvent

# Twilio (SMS) — requis si SMS_PROVIDER=twilio et NOTIFICATIONS_MODE=live
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Clé maîtresse de chiffrement (générer : node -e "console.log(require(\047crypto\047).randomBytes(32).toString(\047base64\047))")
APP_ENCRYPTION_KEY=
